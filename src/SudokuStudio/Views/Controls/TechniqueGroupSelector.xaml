<UserControl
    x:Class="SudokuStudio.Views.Controls.TechniqueGroupSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:bs="using:SudokuStudio.BindableSource"
	xmlns:c="using:SudokuStudio.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=c:TechniqueGroupSelector}">
	<ComboBox
		ItemsSource="{x:Bind ItemsSource}" SelectedIndex="{x:Bind SelectedIndex,Mode=TwoWay}"
		SelectionChanged="ComboBox_SelectionChanged">
		<ComboBox.ItemTemplate>
			<DataTemplate x:DataType="bs:TechniqueGroupBindableSource_IWillChangeThisTypeNameLater">
				<TextBlock Text="{x:Bind DisplayName}" />
			</DataTemplate>
		</ComboBox.ItemTemplate>
	</ComboBox>
</UserControl>
